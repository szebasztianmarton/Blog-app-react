{
  "name": "blog-app",
  "version": "1.0.0",
  "private": true,
  "description": "Egyszeru blog alkalmazas React frontenddel es Express + SQLite backenddel",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "dependencies": {
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "react-scripts": "^5.0.1",
    "tailwindcss": "^3.4.0",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  },
  "scripts": {
    "client": "react-scripts start",
    "client:build": "react-scripts build",
    "client:test": "react-scripts test --watchAll=false",
    "client:test:watch": "react-scripts test",
    "server": "pnpm --dir server start",
    "server:dev": "pnpm --dir server dev",
    "server:install": "pnpm --dir server install",
    "server:seed": "pnpm --dir server seed",
    "server:test": "pnpm --dir server test",
    "dev": "concurrently -k -n SERVER,CLIENT -c yellow,cyan \"pnpm run server\" \"pnpm run client\"",
    "start": "pnpm run dev",
    "build": "pnpm run client:build",
    "test": "pnpm run client:test && pnpm run server:test",
    "install:all": "pnpm install && pnpm --dir server install",
    "seed": "pnpm run server:seed",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "proxy": "http://localhost:4000"
}
