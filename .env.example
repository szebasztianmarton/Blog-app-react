# Backend (server/)
PORT=4000
DB_PATH=./server/data/blog.db

# Frontend (CRA dev server)
# HOST / WDS_SOCKET_HOST tells webpack-dev-server which host to bind to and
# trust; without them CRA 5 throws "options.allowedHosts[0] should be a
# non-empty string" on some Windows setups.
HOST=localhost
WDS_SOCKET_HOST=localhost
# PORT (when overriding the default 3000):
# PORT=3001
REACT_APP_API_URL=http://localhost:4000/api
